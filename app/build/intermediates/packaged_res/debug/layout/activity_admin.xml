<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_admin.xml  (UPDATED)
    Unified with activity_main.xml:
    • elevation="4dp" on the top bar (was missing — user had it)
    • Hamburger menu btn now has a fixed start position; avatar stays right
    • tvPageTitle centred exactly like user layout
    • Avatar text is dynamic ("A" placeholder — AdminActivity sets it from name)
    • Dividers above AND below fragment container to match user symmetry
    • BottomNavigationView height = 62dp, itemIconSize = 22dp (same as user)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <!-- ══════════════════════════════════════
         TOP ADMIN BAR
    ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Hamburger / menu button -->
        <LinearLayout
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="18dp"
                android:layout_height="2dp"
                android:layout_marginBottom="4dp"
                android:background="@color/text_primary" />

            <View
                android:layout_width="18dp"
                android:layout_height="2dp"
                android:layout_marginBottom="4dp"
                android:background="@color/text_primary" />

            <View
                android:layout_width="12dp"
                android:layout_height="2dp"
                android:background="@color/text_primary" />
        </LinearLayout>

        <!-- Page title — centre weighted, same as user -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/admin_panel"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Admin avatar — purple_600 distinguishes from user accent_blue -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvAdminAvatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            app:cardBackgroundColor="@color/purple_600"
            app:cardCornerRadius="17dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/logo">
            </ImageView>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- ══════════════════════════════════════
         BOTTOM NAV  — same height/size as user
    ══════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/bg_surface"
        android:elevation="12dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/admin_nav_selector"
        app:itemTextColor="@color/admin_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_admin_nav" />

</LinearLayout>
