<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml  (UPDATED)
    Unified with activity_admin.xml:
    • Same top header bar height (56dp), bg_surface, elevation + divider
    • tvPageTitle centred, bold 16sp  — mirrors admin tvPageTitle
    • Avatar circle uses accent_blue instead of purple_600 so user vs admin
      are visually distinct at a glance while sharing the same component shape
    • BottomNavigationView styling kept (pill indicator, ripple, elevation)
    • labelVisibilityMode="labeled" kept consistent with admin
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <!-- ══════════════════════════════════════
         TOP HEADER BAR  — mirrors admin bar
    ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- App-name / page title (centre-weighted) -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HTHSHOP"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Cart badge button -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp">
            <!-- Cart item count badge -->
            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_badge_error"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/text_white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <!-- User avatar circle — accent_blue distinguishes from admin purple -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvAvatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            app:cardBackgroundColor="@color/accent_blue"
            app:cardCornerRadius="17dp"
            app:cardElevation="0dp">


            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/logo">
            </ImageView>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Divider — same as admin -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider above nav -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- ══════════════════════════════════════
         BOTTOM NAV  — same height as admin (62dp)
    ══════════════════════════════════════ -->
<!--    <com.google.android.material.bottomnavigation.BottomNavigationView-->
<!--        android:id="@+id/bottomNav"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="62dp"-->
<!--        android:background="@color/bg_surface"-->
<!--        android:elevation="12dp"-->
<!--        app:itemActiveIndicatorStyle="@style/NavIndicatorStyle"-->
<!--        app:itemIconSize="22dp"-->
<!--        app:itemIconTint="@color/nav_item_selector"-->
<!--        app:itemRippleColor="#331A73E8"-->
<!--        app:itemTextColor="@color/nav_item_selector"-->
<!--        app:labelVisibilityMode="labeled"-->
<!--        app:menu="@menu/menu_user_nav" />-->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        app:itemIconTint="@color/admin_nav_selector"
        app:itemTextColor="@color/admin_nav_selector"
        app:menu="@menu/menu_user_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</LinearLayout>
