<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_nav_indicator.xml
    Pill-shaped background used as the active indicator behind the
    selected BottomNavigationView item.
    Color references @color/accent_blue_light so it auto-adapts to
    dark / light mode through the existing color resources.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/accent_blue_light" />
    <corners android:radius="50dp" />
</shape>
